<aside class="sidebar">
  <div class="brand">
    <span class="brand-mark"></span>
    <div>
      <p>PyroWatch</p>
      <strong>Portugal</strong>
    </div>
    <a href="https://github.com/no-tone/pyrowatch" target="_blank" rel="noopener noreferrer" class="github-link" aria-label="GitHub repository">
      <svg width="20" height="20" viewBox="0 0 16 16" fill="currentColor">
        <path d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.013 8.013 0 0016 8c0-4.42-3.58-8-8-8z"/>
      </svg>
    </a>
  </div>

  <section class="panel">
    <label for="metric">Indicador do mapa</label>
    <select id="metric">
      <option value="fires">Incêndios rurais</option>
      <option value="burnedShare">Superfície ardida</option>
    </select>
  </section>

  <section class="panel kpi-panel">
    <p class="panel-title">KPIs disponíveis</p>
    <div class="kpi-list">
      <button class="kpi-source" draggable="true" data-chart="bar">Top regiões</button>
      <button class="kpi-source" draggable="true" data-chart="donut">Distribuição regional</button>
      <button class="kpi-source" draggable="true" data-chart="scatter">Ocorrências vs ardida</button>
      <button class="kpi-source" draggable="true" data-chart="municipalities">Top municípios</button>
      <button class="kpi-source" draggable="true" data-chart="landuse">Tipo de área ardida</button>
      <button class="kpi-source" draggable="true" data-chart="line">Evolução anual</button>
      <button class="kpi-source" draggable="true" data-chart="area">Tendência acumulada</button>
      <button class="kpi-source" draggable="true" data-chart="treemap">Peso regional</button>
      <button class="kpi-source" draggable="true" data-chart="heatmap">Matriz região/indicador</button>
      <button class="kpi-source" draggable="true" data-chart="lollipop">Ranking área ardida</button>
      <button class="kpi-source" draggable="true" data-chart="cards">Resumo nacional</button>
    </div>
  </section>

  <section class="panel source-panel">
    <p class="panel-title">Fonte</p>
    <p>INE via dados.gov.pt</p>
    <small>Incêndios rurais e proporção de superfície ardida. Fonte: ICNF/Estatísticas florestais.</small>
  </section>

  <div class="actions">
    <button id="refresh" type="button" class="icon-btn" aria-label="Refresh data">
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <path d="M21.5 2v6h-6M2.5 22v-6h6M2 11.5a10 10 0 0 1 18.8-4.3M22 12.5a10 10 0 0 1-18.8 4.2"/>
      </svg>
    </button>
    <button id="reset" type="button" class="icon-btn reset-btn" aria-label="Reset dashboard">
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <path d="M3 12a9 9 0 1 0 3-6.7"/>
        <path d="M3 3v6h6"/>
      </svg>
    </button>
  </div>
</aside>
